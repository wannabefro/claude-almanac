{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m claude_almanac.hooks.retrieve"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m claude_almanac.hooks.curate"
          }
        ]
      }
    ]
  }
}
